{
  "name": "cycling-race-game",
  "version": "0.1.0",
  "description": "Cycling race board game simulator",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "pnpm --dir ./ptest exec playwright test",
    "test:e2e:ui": "pnpm --dir ./ptest exec playwright test --ui",
    "test:e2e:headed": "pnpm --dir ./ptest exec playwright test --headed",
    "test:e2e:debug": "pnpm --dir ./ptest exec playwright test --debug",
    "test:e2e:report": "pnpm --dir ./ptest exec playwright show-report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "jsdom": "^27.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
